# Copy this file to .env and fill in your values
# For quick local testing with SQLite, set USE_SQLITE=True

SECRET_KEY=django-insecure-change-this-before-production-123456

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (default)
DB_NAME=sewingshop_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Set to True to use SQLite instead of PostgreSQL (easier local setup)
USE_SQLITE=True
